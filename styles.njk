{% include "src/css/variables.css" %}

/* Custom Overrides on top of Bootstrap */
@font-face {
    font-family: 'Almarai';
    src: url('/assets/fonts/Almarai-Bold.ttf') format('truetype');
    font-weight: bold;
    font-style: normal;
    font-display: swap;
}

/* Font Loaded from Local */
/* :root variables are loaded from src/css/variables.css */

/* Aggressive Compression with Massive White Space */
html {
    font-size: 11px; /* Extremely small base size */
}

body {
    direction: rtl;
    text-align: right;
    font-family: 'Almarai', sans-serif;
    background-color: #f8f9fa;
    line-height: 2.2; /* Very airy text to compensate for small size */
}

/* Massive Spacing (Negative Space) */
section, main {
    margin-bottom: 8rem; /* Ultra huge vertical gaps */
    padding-top: 0; /* Removed to fix Navbar-Header gap */
    padding-bottom: 2rem;
}

/* Horizontal Breathing Room */
.container {
    max-width: 1200px;
    padding-left: 3rem;
    padding-right: 3rem;
}

/* Tiny Headers but Airy */
h1 { font-size: 1.6rem !important; margin-bottom: 1.5rem; letter-spacing: 0.5px; }
h2 { font-size: 1.4rem !important; margin-bottom: 1.2rem; }
h3 { font-size: 1.2rem !important; margin-bottom: 1rem; }
h4 { font-size: 1.1rem !important; margin-bottom: 0.8rem; }
h5, h6 { font-size: 1rem !important; margin-bottom: 0.5rem; }

/* Half-Size Component Overrides */
.btn {
    padding: 0.2rem 0.6rem !important; /* Half normal padding */
    font-size: 0.9rem !important;
    border-radius: 4px !important; /* Less rounded to look sharper/smaller */
    min-height: auto !important;
}
.btn-lg {
    padding: 0.3rem 0.8rem !important;
    font-size: 1rem !important;
}

/* Compact Cards */
.card {
    margin-bottom: 2rem;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.03);
}
.card-body {
    padding: 0.8rem !important; /* Very tight internal spacing */
}
.card-title {
    font-size: 1.1rem !important;
    margin-bottom: 0.5rem !important;
}
.card-text {
    font-size: 0.9rem !important;
}
.product-price {
    font-size: 1rem !important;
}
.product-image {
    height: 180px !important; /* Force smaller images */
    object-fit: cover;
}

/* Form Inputs */
.form-control, .form-select {
    padding: 0.25rem 0.5rem !important;
    font-size: 0.9rem !important;
    height: auto !important;
}

/* Navbar Ultra-Compact (1/3 Size) */
.navbar {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    min-height: 40px !important; /* Force very short height */
    background: var(--primary-wood) !important; /* Pure Red Background */
}
.navbar-brand img {
    height: 30px !important; /* Tiny Logo */
}
.navbar-dark .navbar-nav .nav-link {
    font-size: 0.8rem !important;
    padding: 0.15rem 0.5rem !important; /* Minimal padding */
    line-height: 1;
}
/* Search Placeholder Opacity */
.navbar input::placeholder {
    color: rgba(255, 255, 255, 0.7) !important;
}
.navbar input:focus {
    background-color: rgba(255, 255, 255, 0.2) !important;
}

/* Floating Buttons - Micro Sized */
.floating-btn-container {
    gap: 0.5rem !important;
    bottom: 1rem !important;
    left: 1rem !important;
}
.floating-btn {
    width: 35px !important;
    height: 35px !important;
    font-size: 0.9rem !important;
    padding: 0 !important;
}

/* Color Overrides for Red/Black/White Theme */
.text-warning { color: #000000 !important; } /* Highlights are Black */
.bg-warning { background-color: #000000 !important; }
.btn-warning {
    background-color: #000000;
    border-color: #000000;
    color: #fff;
}
.btn-primary {
    background-color: var(--primary-wood);
    border-color: var(--primary-wood);
}
.btn-outline-primary {
    color: var(--primary-wood);
    border-color: var(--primary-wood);
}
.btn-outline-primary:hover {
    background-color: var(--primary-wood);
    color: #fff;
}

/* Section Backgrounds - Strip Beige */
.bg-light, section.bg-light {
    background-color: #FFFFFF !important;
}

/* Button Scaling */
.btn {
    padding: 0.25rem 0.75rem;
    font-size: 0.85rem;
}
.btn-lg {
    padding: 0.4rem 1rem;
    font-size: 1rem;
}
.navbar-dark .navbar-nav .nav-link:hover,
.navbar-dark .navbar-nav .nav-link:focus {
    color: var(--gold-accent);
    background-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
}

/* Card Hover Effect */
.hover-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.hover-lift:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
}

/* Group Hover Effect for Products */
.group-hover-effect:hover .product-image img {
    transform: scale(1.05);
}
.transition-transform {
    transition: transform 0.5s ease;
}

/* Universe Navbar Styles */
.universe-navbar {
    background: rgba(211, 47, 47, 0.95); /* Red with slight transparency */
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
}

/* 1. Expandable Search */
.search-container {
    position: relative;
    display: flex;
    align-items: center;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.search-input-wrapper {
    width: 0;
    overflow: hidden;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
}
.search-container.active .search-input-wrapper {
    width: 250px; /* Expanded Width */
    opacity: 1;
    margin-left: 10px;
}
.search-input {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
    border-radius: 20px;
    padding: 5px 15px;
    width: 100%;
}
.search-input::placeholder { color: rgba(255,255,255,0.7); }
.search-btn {
    background: none;
    border: none;
    color: white;
    font-size: 1.2rem;
    cursor: pointer;
    transition: transform 0.3s ease;
}
.search-btn:hover { transform: scale(1.1); }

/* 2. Mega Menu / Smart Dropdowns */
.nav-item.dropdown {
    position: relative;
}
.dropdown-menu-custom {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    padding: 1rem;
    min-width: 200px;
    opacity: 0;
    transition: all 0.3s ease;
    z-index: 1050;
    border: none;
}
.nav-item:hover .dropdown-menu-custom {
    display: block;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
}

/* Offers Hover Preview */
.offers-dropdown {
    width: 400px;
    display: flex;
    gap: 1rem;
}
.offers-list {
    flex: 1;
    list-style: none;
    padding: 0;
    margin: 0;
}
.offer-link {
    display: block;
    padding: 8px 12px;
    border-radius: 6px;
    color: var(--dark-text);
    text-decoration: none;
    transition: background 0.2s;
    font-size: 0.9rem;
}
.offer-link:hover {
    background: #f0f0f0;
    color: var(--primary-wood);
}
.offer-preview {
    flex: 1;
    background: #f9f9f9;
    border-radius: 8px;
    padding: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}
.preview-img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 6px;
    margin-bottom: 10px;
}

/* Branches Cards */
.branch-item {
    padding: 10px;
    border-bottom: 1px solid #eee;
    transition: background 0.2s;
}
.branch-item:last-child { border-bottom: none; }
.branch-item:hover { background: #f9f9f9; }
.branch-details {
    display: none; /* Hidden by default, shown via JS or refined CSS */
    font-size: 0.8rem;
    color: #666;
    margin-top: 5px;
}
.branch-item:hover .branch-details { display: block; }

/* Blur Backdrop for Search */
.search-overlay {
    position: fixed;
    top: 60px; /* Below Navbar */
    left: 0;
    width: 100%;
    height: calc(100vh - 60px);
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(5px);
    z-index: 999;
    display: none;
    opacity: 0;
    transition: opacity 0.3s;
}
.search-overlay.active { display: block; opacity: 1; }

/* Action Buttons (Header Right) */
.header-actions .btn-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: white;
    color: var(--primary-wood);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}
.header-actions .btn-icon:hover {
    background: var(--primary-wood); /* Red */
    color: white;
    transform: translateY(-2px);
}


