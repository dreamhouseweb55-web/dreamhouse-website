<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    <title>{{ title }} - {{ settings.siteName }}</title>
    <meta name="description" content="{{ description or settings.description }}">
    <meta name="keywords" content="{{ settings.keywords }}">
    <meta name="author" content="{{ settings.siteNameEn }}">
    
    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title }} - {{ settings.siteName }}">
    <meta property="og:description" content="{{ description or settings.description }}">
    <meta property="og:site_name" content="{{ settings.siteNameEn }}">
    
    <!-- Bootstrap RTL CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLzUCCUXOY2j/LSvXYuG6Bqs43ALlhIqAJVRb" crossorigin="anonymous">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png?v=2">
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico?v=2">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Custom Styles (For Branding Overrides) -->
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <!-- Universe Navbar (Fixed) -->
    <nav class="navbar navbar-expand-lg fixed-top universe-navbar p-0">
        <div class="container-fluid px-4 h-100 d-flex align-items-center" style="min-height: 80px;">
            
            <!-- 1. Left: Logo (English) -->
            <a class="navbar-brand me-auto" href="/">
                <div class="d-flex align-items-center gap-2">
                   <!-- Logo Icon -->
                   <img src="{{ settings.logoWhite }}" alt="Dream House" height="40">
                   <!-- English Text -->
                   <div class="d-flex flex-column" style="line-height: 1;">
                       <span class="h4 mb-0 text-white fw-bold text-uppercase d-none d-sm-block" style="font-family: 'Outfit', sans-serif; letter-spacing: 2px;">DREAM HOUSE</span>
                   </div>
                </div>
            </a>

            <!-- Mobile Toggler -->
            <button class="navbar-toggler border-0 p-0 text-white ms-3 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                <div class="hamburger-icon">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </button>

            <!-- 2. Right: Links + Actions (Grouped) -->
            <div class="collapse navbar-collapse flex-grow-0" id="navContent">
                <div class="d-flex flex-column flex-lg-row align-items-end align-items-lg-center gap-4">
                    
                    <!-- Navigation Links -->
                    <ul class="navbar-nav align-items-center gap-3 order-2 order-lg-1">
                        <li class="nav-item"><a class="nav-link text-white fw-bold hover-underline" href="/">HOME</a></li>
                        
                        <!-- Products Nested Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link text-white fw-bold dropdown-toggle hover-underline" href="/products/" data-bs-auto-close="outside">PRODUCTS</a>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-0 overflow-hidden" style="min-width: 220px;">
                                <!-- Bedrooms -->
                                <li class="dropend">
                                    <a class="dropdown-item d-flex justify-content-between align-items-center py-2 px-3" href="#" data-bs-toggle="dropdown">
                                        Bedrooms <i class="fas fa-chevron-right small ms-2"></i>
                                    </a>
                                    <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-2 submenu">
                                        <li><a class="dropdown-item rounded-2" href="/products/#bedrooms">Master Bedrooms</a></li>
                                        <li><a class="dropdown-item rounded-2" href="/products/#kids">Kids Bedrooms</a></li>
                                        <li><a class="dropdown-item rounded-2" href="/products/#wardrobes">Wardrobes</a></li>
                                    </ul>
                                </li>
                                <!-- Living -->
                                <li class="dropend">
                                    <a class="dropdown-item d-flex justify-content-between align-items-center py-2 px-3" href="#" data-bs-toggle="dropdown">
                                        Living Room <i class="fas fa-chevron-right small ms-2"></i>
                                    </a>
                                    <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-2 submenu">
                                        <li><a class="dropdown-item rounded-2" href="/products/#sofas">Sofas</a></li>
                                        <li><a class="dropdown-item rounded-2" href="/products/#corners">Corners</a></li>
                                        <li><a class="dropdown-item rounded-2" href="/products/#tv-units">TV Units</a></li>
                                    </ul>
                                </li>
                                <!-- Kitchens -->
                                <li><a class="dropdown-item py-2 px-3" href="/products/#kitchens">Kitchens</a></li>
                            </ul>
                        </li>

                        <!-- Offers Smart Dropdown -->
                        <li class="nav-item dropdown position-static">
                            <a class="nav-link text-white fw-bold dropdown-toggle hover-underline" href="/offers/">OFFERS</a>
                            <div class="dropdown-menu w-100 shadow-lg border-0 rounded-0 mt-0 p-4" style="left: 0; right: 0;">
                                <div class="container">
                                    <div class="row">
                                        <div class="col-md-4 mb-3 mb-md-0">
                                            <h6 class="text-uppercase fw-bold text-danger mb-3">Latest Offers</h6>
                                            <ul class="list-unstyled">
                                                {% for product in products.products | selectattr("id", "match", "offer") | slice(4) %}
                                                <li>
                                                    <a href="/products/#{{ product.id }}" class="d-block py-2 text-dark text-decoration-none border-bottom offer-hover-item"
                                                       data-img="{{ product.image }}" data-price="{{ product.price }}" data-title="{{ product.name }}">
                                                        {{ product.name }}
                                                        <span class="badge bg-danger rounded-pill float-end">{{ product.price }} LE</span>
                                                    </a>
                                                </li>
                                                {% endfor %}
                                            </ul>
                                        </div>
                                        <div class="col-md-8">
                                            <div class="offer-preview-card p-3 rounded-4 bg-light h-100 d-flex align-items-center justify-content-center position-relative overflow-hidden">
                                                <img src="/images/offer-main.webp" id="megaMenuPreviewImg" class="img-fluid rounded-3 shadow-sm" style="max-height: 250px; object-fit: cover; transition: transform 0.5s;">
                                                <div class="position-absolute bottom-0 start-0 w-100 p-3 bg-white bg-opacity-90 backdrop-blur">
                                                    <h5 class="fw-bold m-0" id="megaMenuPreviewTitle">Special Offers</h5>
                                                    <p class="text-danger fw-bold m-0" id="megaMenuPreviewPrice">Up to 30% OFF</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </li>

                        <!-- Branches Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link text-white fw-bold dropdown-toggle hover-underline" href="/branches/">BRANCHES</a>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-2" style="min-width: 250px;">
                                {% for branch in branches_page.branches %}
                                <li class="position-relative branch-hover-item p-2 rounded-2">
                                    <div class="fw-bold">{{ branch.name }}</div>
                                    <small class="text-muted d-block text-truncate">{{ branch.address }}</small>
                                    
                                    <!-- Hover Detail Popup -->
                                    <div class="branch-popup position-absolute top-0 start-100 ms-2 bg-white shadow-lg p-3 rounded-3" style="width: 200px; display: none; z-index: 100;">
                                        <h6 class="small fw-bold">{{ branch.name }}</h6>
                                        <p class="small text-muted mb-2">{{ branch.phone }}</p>
                                        <a href="{{ branch.mapLink }}" target="_blank" class="btn btn-sm btn-danger w-100 rounded-pill">Get Directions</a>
                                    </div>
                                </li>
                                {% endfor %}
                            </ul>
                        </li>
                    </ul>

                    <!-- Actions -->
                    <div class="header-actions d-flex gap-2 order-1 order-lg-2 ms-lg-4">
                        <!-- Search Toggle -->
                        <button class="btn btn-white-glass rounded-circle p-2 d-flex align-items-center justify-content-center" onclick="openSearchOverlay()" style="width: 45px; height: 45px;">
                            <i class="fas fa-search"></i>
                        </button>
                        
                        <!-- Cart -->
                        <button class="btn btn-white-glass rounded-circle p-2 d-flex align-items-center justify-content-center position-relative" data-bs-toggle="offcanvas" data-bs-target="#cartSidebar" style="width: 45px; height: 45px;">
                            <i class="fas fa-shopping-cart"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-2 border-white" style="font-size: 0.6rem;">0</span>
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </nav>

    <!-- Full Screen Search Overlay -->
    <div id="fullScreenSearch" class="fixed-top w-100 h-100 d-none" style="z-index: 2000; background: rgba(0,0,0,0.4); backdrop-filter: blur(20px);">
        <button class="btn btn-close btn-close-white position-absolute top-0 start-0 m-4 fs-3" onclick="closeSearchOverlay()"></button>
        <div class="container h-100 d-flex flex-column align-items-center justify-content-center">
            <h2 class="text-white mb-4 fw-bold">Search Products</h2>
            <div class="w-100" style="max-width: 700px;">
                <input type="text" id="overlaySearchInput" class="form-control form-control-lg rounded-pill border-0 shadow-lg py-3 px-4 fs-5" placeholder="Type to search (e.g. Bed, Sofa)...">
            </div>
            <div id="searchResultsGrid" class="row g-4 mt-4 w-100 overflow-auto justify-content-center" style="max-height: 60vh;">
                <!-- Results injected here -->
            </div>
        </div>
    </div>

    <script>
        // Search Overlay Logic
        function openSearchOverlay() {
            document.getElementById('fullScreenSearch').classList.remove('d-none');
            document.getElementById('fullScreenSearch').classList.add('d-block');
            setTimeout(() => document.getElementById('overlaySearchInput').focus(), 100);
        }
        function closeSearchOverlay() {
            document.getElementById('fullScreenSearch').classList.add('d-none');
            document.getElementById('fullScreenSearch').classList.remove('d-block');
        }

        // Live Search Mockup
        const searchInput = document.getElementById('overlaySearchInput');
        searchInput.addEventListener('input', (e) => {
            const val = e.target.value.toLowerCase();
            const grid = document.getElementById('searchResultsGrid');
            if (val.length < 2) { grid.innerHTML = ''; return; }
            
            // Mock Results (In a real scenario, filter 'products.json' passed to JS)
            // For visual effect:
            grid.innerHTML = `
                <div class="col-6 col-md-3 animate__animated animate__fadeInUp">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                        <img src="/images/offer-main.webp" class="card-img-top" style="height: 120px; object-fit: cover;">
                        <div class="card-body p-2 text-center">
                            <h6 class="small fw-bold mb-1">Result Product</h6>
                            <span class="text-danger small fw-bold">12,000 LE</span>
                        </div>
                    </div>
                </div>
                 <div class="col-6 col-md-3 animate__animated animate__fadeInUp" style="animation-delay: 0.1s">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                        <img src="/images/offer-main.webp" class="card-img-top" style="height: 120px; object-fit: cover;">
                        <div class="card-body p-2 text-center">
                            <h6 class="small fw-bold mb-1">Another Product</h6>
                            <span class="text-danger small fw-bold">8,500 LE</span>
                        </div>
                    </div>
                </div>
            `;
        });

        // Offers Hover Logic
        document.querySelectorAll('.offer-hover-item').forEach(item => {
            item.addEventListener('mouseenter', () => {
                const img = item.getAttribute('data-img');
                const title = item.getAttribute('data-title');
                const price = item.getAttribute('data-price');
                
                document.getElementById('megaMenuPreviewImg').src = img;
                document.getElementById('megaMenuPreviewTitle').innerText = title;
                document.getElementById('megaMenuPreviewPrice').innerText = price + " LE";
            });
        });

        // Branches Hover Logic
        document.querySelectorAll('.branch-hover-item').forEach(item => {
            item.addEventListener('mouseenter', () => {
                item.querySelector('.branch-popup').style.display = 'block';
            });
            item.addEventListener('mouseleave', () => {
                item.querySelector('.branch-popup').style.display = 'none';
            });
        });
    </script>

    <main style="padding-top: 80px;"> <!-- Push content down due to fixed navbar -->
        {{ content | safe }}
    </main>

    <!-- Cart Offcanvas (Existing Structure) -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="cartSidebar" aria-labelledby="cartSidebarLabel">
        <div class="offcanvas-header text-white" style="background-color: var(--primary-wood);">
            <h5 class="offcanvas-title small" id="cartSidebarLabel">السلة</h5>
            <button type="button" class="btn-close btn-close-white text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column p-0">
            <div id="cartItems" class="flex-grow-1 p-3 overflow-auto small"></div>
            <div class="border-top p-3 bg-white">
                <div class="d-flex justify-content-between mb-3 fw-bold text-dark small">
                    <span>الإجمالي:</span>
                    <span class="total-price text-danger">0 ج.م</span>
                </div>
                <button class="btn w-100 btn-dark btn-sm d-flex align-items-center justify-content-center gap-2 py-2" id="checkoutBtn">
                    <i class="fab fa-whatsapp"></i> <span>طلب واتساب</span>
                </button>
            </div>
        </div>
    </div>


    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-3 mt-5 border-top border-warning border-3" style="background: linear-gradient(135deg, #2c2c2c 0%, #1a1a1a 100%);">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3 text-warning">عن {{ settings.siteName }}</h5>
                    <p class="text-white-50 small" style="line-height: 1.8;">{{ settings.footer.aboutText }}</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="{{ settings.social.facebook }}" target="_blank" class="text-white text-decoration-none hover-lift"><i class="fab fa-facebook-f"></i></a>
                        <a href="{{ settings.social.instagram }}" target="_blank" class="text-white text-decoration-none hover-lift"><i class="fab fa-instagram"></i></a>
                        <a href="{{ settings.social.tiktok }}" target="_blank" class="text-white text-decoration-none hover-lift"><i class="fab fa-tiktok"></i></a>
                        <a href="https://wa.me/{{ settings.contact.whatsapp }}" target="_blank" class="text-white text-decoration-none hover-lift"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>
                
                <div class="col-lg-2 col-6">
                    <h5 class="fw-bold mb-3 text-warning">روابط سريعة</h5>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-2"><a href="/" class="text-decoration-none text-white-50 hover-text-white transition-all">الرئيسية</a></li>
                        <li class="mb-2"><a href="/#about" class="text-decoration-none text-white-50 hover-text-white transition-all">من نحن</a></li>
                        <li class="mb-2"><a href="/products/" class="text-decoration-none text-white-50 hover-text-white transition-all">المنتجات</a></li>
                        <li class="mb-2"><a href="/offers/" class="text-decoration-none text-white-50 hover-text-white transition-all">العروض الخاصة</a></li>
                        <li class="mb-2"><a href="/branches/" class="text-decoration-none text-white-50 hover-text-white transition-all">الفروع</a></li>
                        <li class="mb-2"><a href="/contact/" class="text-decoration-none text-white-50 hover-text-white transition-all">اتصل بنا</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-3 col-6">
                    <h5 class="fw-bold mb-3 text-warning">منتجاتنا</h5>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-2"><a href="/products/#bedrooms" class="text-decoration-none text-white-50 hover-text-white transition-all">غرف نوم رئيسية</a></li>
                        <li class="mb-2"><a href="/products/#kids-bedrooms" class="text-decoration-none text-white-50 hover-text-white transition-all">غرف نوم أطفال</a></li>
                        <li class="mb-2"><a href="/products/#sofas" class="text-decoration-none text-white-50 hover-text-white transition-all">أنتريهات</a></li>
                        <li class="mb-2"><a href="/products/#corners" class="text-decoration-none text-white-50 hover-text-white transition-all">ركنات</a></li>
                        <li class="mb-2"><a href="/products/#dining" class="text-decoration-none text-white-50 hover-text-white transition-all">غرف سفرة</a></li>
                        <li class="mb-2"><a href="/products/#kitchens" class="text-decoration-none text-white-50 hover-text-white transition-all">مطابخ</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3 text-warning">تواصل معنا</h5>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-phone text-warning"></i> <span dir="ltr">{{ settings.contact.phone }}</span></li>
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-envelope text-warning"></i> {{ settings.contact.email }}</li>
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-map-marker-alt text-warning"></i> مدينة نصر، القاهرة</li>
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-map-marker-alt text-warning"></i> 6 أكتوبر، الجيزة</li>
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-clock text-warning"></i> السبت - الخميس: 10 ص - 10 م</li>
                    </ul>
                </div>
            </div>
            
            <hr class="border-secondary my-4">
            
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-end mb-3 mb-md-0">
                    <p class="mb-0 text-white-50 small">&copy; {{ settings.footer.copyright }}</p>
                </div>
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0 text-white-50 small">{{ settings.footer.credits }}</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="/script.js"></script>

