<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    <title>{{ title }} - {{ settings.siteName }}</title>
    <meta name="description" content="{{ description or settings.description }}">
    <meta name="keywords" content="{{ settings.keywords }}">
    <meta name="author" content="{{ settings.siteNameEn }}">
    
    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title }} - {{ settings.siteName }}">
    <meta property="og:description" content="{{ description or settings.description }}">
    <meta property="og:site_name" content="{{ settings.siteNameEn }}">
    
    <!-- Bootstrap RTL CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLzUCCUXOY2j/LSvXYuG6Bqs43ALlhIqAJVRb" crossorigin="anonymous">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png?v=2">
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico?v=2">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Custom Styles (For Branding Overrides) -->
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <!-- Strict Navbar (User Specified) -->
    <nav class="navbar navbar-expand-lg fixed-top universe-navbar p-0">
        <div class="container-fluid px-4 h-100 d-flex flex-row-reverse justify-content-between align-items-center" style="min-height: 80px;">
            
            <!-- 1. Left: Logo (Image Only, No Extra Text) -->
            <a class="navbar-brand m-0" href="/">
                <img src="{{ settings.logoWhite }}" alt="Dream House" height="45">
            </a>

            <!-- Mobile Toggler -->
            <button class="navbar-toggler border-0 p-0 text-white d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                <div class="hamburger-icon">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </button>

            <!-- 2. Right: Search + Navigation Links -->
            <div class="collapse navbar-collapse flex-grow-0" id="navContent">
                <div class="d-flex flex-column flex-lg-row align-items-end align-items-lg-center gap-4">
                    
                    <!-- Search Icon (Expands on Click) -->
                    <div class="search-trigger order-1 order-lg-2 ms-lg-3">
                        <button class="btn text-white p-0 border-0" onclick="openSearchOverlay()" title="Search">
                            <i class="fas fa-search fa-lg hover-scale"></i>
                        </button>
                    </div>

                    <!-- Navigation Links -->
                    <ul class="navbar-nav align-items-center gap-3 order-2 order-lg-1">
                        <li class="nav-item"><a class="nav-link text-white fw-bold hover-underline" href="/">HOME</a></li>
                        
                        <!-- Products Tree Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link text-white fw-bold dropdown-toggle hover-underline" href="#" data-bs-auto-close="outside">PRODUCTS</a>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-0" style="min-width: 220px;">
                                <!-- Category: Bedrooms -->
                                <li class="dropend">
                                    <a class="dropdown-item d-flex justify-content-between align-items-center py-2 px-3" href="#" data-bs-toggle="dropdown">
                                        Bedrooms <i class="fas fa-chevron-right small ms-2"></i>
                                    </a>
                                    <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-2 submenu">
                                        {% for product in products.products | selectattr("category", "equalto", "bedrooms") %}
                                        <li><a class="dropdown-item rounded-2 small" href="/products/#{{ product.id }}">{{ product.name }}</a></li>
                                        {% endfor %}
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item rounded-2 fw-bold text-danger" href="/products/#bedrooms">View All</a></li>
                                    </ul>
                                </li>
                                <!-- Category: Living -->
                                <li class="dropend">
                                    <a class="dropdown-item d-flex justify-content-between align-items-center py-2 px-3" href="#" data-bs-toggle="dropdown">
                                        Living <i class="fas fa-chevron-right small ms-2"></i>
                                    </a>
                                    <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-2 submenu">
                                        {% for product in products.products | selectattr("category", "equalto", "living") %}
                                        <li><a class="dropdown-item rounded-2 small" href="/products/#{{ product.id }}">{{ product.name }}</a></li>
                                        {% endfor %}
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item rounded-2 fw-bold text-danger" href="/products/#sofas">View All</a></li>
                                    </ul>
                                </li>
                                <!-- Category: Kitchens -->
                                <li class="dropend">
                                    <a class="dropdown-item d-flex justify-content-between align-items-center py-2 px-3" href="#" data-bs-toggle="dropdown">
                                        Kitchens <i class="fas fa-chevron-right small ms-2"></i>
                                    </a>
                                    <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-2 submenu">
                                         {% for product in products.products | selectattr("category", "equalto", "kitchens") %}
                                        <li><a class="dropdown-item rounded-2 small" href="/products/#{{ product.id }}">{{ product.name }}</a></li>
                                        {% endfor %}
                                         <li><a class="dropdown-item rounded-2 fw-bold text-danger" href="/products/#kitchens">View All</a></li>
                                    </ul>
                                </li>
                            </ul>
                        </li>

                        <!-- Offers Dropdown (Hover Preview) -->
                        <li class="nav-item dropdown">
                            <a class="nav-link text-white fw-bold dropdown-toggle hover-underline" href="/offers/">OFFERS</a>
                            <div class="dropdown-menu shadow-lg border-0 rounded-3 p-2" style="min-width: 300px;">
                                {% for product in products.products | selectattr("id", "match", "offer") %}
                                <div class="offer-item position-relative p-2 rounded-2 border-bottom">
                                    <a href="/products/#{{ product.id }}" class="text-dark text-decoration-none fw-bold d-block">
                                        {{ product.name }} <span class="badge bg-danger ms-2">{{ product.price }} LE</span>
                                    </a>
                                    <!-- Hover Card -->
                                    <div class="offer-preview-popup position-absolute top-0 start-100 ms-2 bg-white shadow-lg rounded-3 overflow-hidden p-0" style="width: 200px; display: none; z-index: 1000;">
                                        <img src="{{ product.image }}" class="w-100" style="height: 120px; object-fit: cover;">
                                        <div class="p-2 text-center bg-light">
                                            <p class="small m-0 text-danger fw-bold">Click to View</p>
                                        </div>
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                        </li>

                        <!-- Branches Dropdown (Hover Details) -->
                        <li class="nav-item dropdown">
                            <a class="nav-link text-white fw-bold dropdown-toggle hover-underline" href="/branches/">BRANCHES</a>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-3 p-2" style="min-width: 250px;">
                                {% for branch in branches_page.branches %}
                                <li class="position-relative branch-hover-item p-2 rounded-2 border-bottom">
                                    <div class="fw-bold">{{ branch.name }}</div>
                                    <!-- Hover Detail Popup -->
                                    <div class="branch-popup position-absolute top-0 start-100 ms-2 bg-white shadow-lg p-3 rounded-3 border" style="width: 220px; display: none; z-index: 100;">
                                        <h6 class="small fw-bold text-danger">{{ branch.name }}</h6>
                                        <p class="small text-muted mb-2">{{ branch.address }}</p>
                                        <p class="small text-muted mb-2"><i class="fas fa-phone me-1"></i> {{ branch.phone }}</p>
                                        <a href="{{ branch.mapLink }}" target="_blank" class="btn btn-sm btn-dark w-100 rounded-pill">Go to Map</a>
                                    </div>
                                </li>
                                {% endfor %}
                            </ul>
                        </li>

                        <li class="nav-item"><a class="nav-link text-white fw-bold hover-underline" href="/contact/">CONTACT</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- Full Screen Search Overlay -->
    <div id="fullScreenSearch" class="fixed-top w-100 h-100 d-none" style="z-index: 2000; background: rgba(0,0,0,0.6); backdrop-filter: blur(15px);">
        <button class="btn btn-close btn-close-white position-absolute top-0 start-0 m-4 fs-3" onclick="closeSearchOverlay()"></button>
        <div class="container h-100 d-flex flex-column align-items-center justify-content-center">
            <h2 class="text-white mb-4 fw-bold">Type to Search</h2>
            <div class="w-100" style="max-width: 600px;">
                <input type="text" id="overlaySearchInput" class="form-control form-control-lg rounded-pill border-0 shadow-lg py-3 px-4 fs-5" placeholder="e.g. Modern Sofa...">
            </div>
            <div id="searchResultsGrid" class="row g-3 mt-4 w-100 overflow-auto justify-content-center" style="max-height: 50vh;"></div>
        </div>
    </div>

    <!-- Floating Buttons (Restored to Bottom Left) -->
    <div class="position-fixed bottom-0 start-0 m-3 d-flex flex-column gap-2 floating-btn-container" style="z-index: 1050;">
        <a href="https://wa.me/{{ settings.contact.whatsapp }}" target="_blank" class="btn btn-success rounded-circle d-flex align-items-center justify-content-center shadow-lg floating-btn" style="width: 50px; height: 50px;">
            <i class="fab fa-whatsapp fa-lg"></i>
        </a>
        <button class="btn btn-dark rounded-circle d-flex align-items-center justify-content-center shadow-lg position-relative floating-btn" style="width: 50px; height: 50px; background-color: #000000; border:none;" data-bs-toggle="offcanvas" data-bs-target="#cartSidebar">
            <i class="fas fa-shopping-cart fa-lg"></i>
            <span class="cart-count position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">0</span>
        </button>
    </div>

    <!-- JS Logic -->
    <script>
        function openSearchOverlay() {
            document.getElementById('fullScreenSearch').classList.remove('d-none');
            document.getElementById('fullScreenSearch').classList.add('d-block');
            setTimeout(() => document.getElementById('overlaySearchInput').focus(), 100);
        }
        function closeSearchOverlay() {
            document.getElementById('fullScreenSearch').classList.add('d-none');
            document.getElementById('fullScreenSearch').classList.remove('d-block');
        }

        // Live Search Logic (Client Side Filtering)
        const productsData = [
            {% for p in products.products %}
            { id: "{{ p.id }}", name: "{{ p.name }}", price: "{{ p.price }}", image: "{{ p.image }}" },
            {% endfor %}
        ];

        document.getElementById('overlaySearchInput').addEventListener('input', function(e) {
            const val = e.target.value.toLowerCase();
            const grid = document.getElementById('searchResultsGrid');
            grid.innerHTML = '';
            
            if(val.length < 2) return;

            const filtered = productsData.filter(p => p.name.toLowerCase().includes(val));
            
            if(filtered.length === 0) {
                 grid.innerHTML = '<p class="text-white-50 text-center">No results found.</p>';
                 return;
            }

            filtered.forEach(p => {
                grid.innerHTML += `
                    <div class="col-6 col-md-4">
                        <a href="/products/#${p.id}" class="card h-100 border-0 rounded-3 overflow-hidden text-decoration-none shadow-sm" style="transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
                            <img src="${p.image}" class="card-img-top" style="height: 100px; object-fit: cover;">
                            <div class="card-body p-2 text-center bg-white">
                                <h6 class="small fw-bold text-dark mb-1">${p.name}</h6>
                                <span class="badge bg-danger">${p.price} LE</span>
                            </div>
                        </a>
                    </div>
                `;
            });
        });

        // Smart Hover Logic using CSS is preferred, but JS fallback for complex popups
        document.querySelectorAll('.offer-item').forEach(item => {
            const popup = item.querySelector('.offer-preview-popup');
            item.addEventListener('mouseenter', () => popup.style.display = 'block');
            item.addEventListener('mouseleave', () => popup.style.display = 'none');
        });

        document.querySelectorAll('.branch-hover-item').forEach(item => {
            const popup = item.querySelector('.branch-popup');
            item.addEventListener('mouseenter', () => popup.style.display = 'block');
            item.addEventListener('mouseleave', () => popup.style.display = 'none');
        });
    </script>


    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-3 mt-5 border-top border-warning border-3" style="background: linear-gradient(135deg, #2c2c2c 0%, #1a1a1a 100%);">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3 text-warning">عن {{ settings.siteName }}</h5>
                    <p class="text-white-50 small" style="line-height: 1.8;">{{ settings.footer.aboutText }}</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="{{ settings.social.facebook }}" target="_blank" class="text-white text-decoration-none hover-lift"><i class="fab fa-facebook-f"></i></a>
                        <a href="{{ settings.social.instagram }}" target="_blank" class="text-white text-decoration-none hover-lift"><i class="fab fa-instagram"></i></a>
                        <a href="{{ settings.social.tiktok }}" target="_blank" class="text-white text-decoration-none hover-lift"><i class="fab fa-tiktok"></i></a>
                        <a href="https://wa.me/{{ settings.contact.whatsapp }}" target="_blank" class="text-white text-decoration-none hover-lift"><i class="fab fa-whatsapp"></i></a>
                    </div>
                </div>
                
                <div class="col-lg-2 col-6">
                    <h5 class="fw-bold mb-3 text-warning">روابط سريعة</h5>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-2"><a href="/" class="text-decoration-none text-white-50 hover-text-white transition-all">الرئيسية</a></li>
                        <li class="mb-2"><a href="/#about" class="text-decoration-none text-white-50 hover-text-white transition-all">من نحن</a></li>
                        <li class="mb-2"><a href="/products/" class="text-decoration-none text-white-50 hover-text-white transition-all">المنتجات</a></li>
                        <li class="mb-2"><a href="/offers/" class="text-decoration-none text-white-50 hover-text-white transition-all">العروض الخاصة</a></li>
                        <li class="mb-2"><a href="/branches/" class="text-decoration-none text-white-50 hover-text-white transition-all">الفروع</a></li>
                        <li class="mb-2"><a href="/contact/" class="text-decoration-none text-white-50 hover-text-white transition-all">اتصل بنا</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-3 col-6">
                    <h5 class="fw-bold mb-3 text-warning">منتجاتنا</h5>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-2"><a href="/products/#bedrooms" class="text-decoration-none text-white-50 hover-text-white transition-all">غرف نوم رئيسية</a></li>
                        <li class="mb-2"><a href="/products/#kids-bedrooms" class="text-decoration-none text-white-50 hover-text-white transition-all">غرف نوم أطفال</a></li>
                        <li class="mb-2"><a href="/products/#sofas" class="text-decoration-none text-white-50 hover-text-white transition-all">أنتريهات</a></li>
                        <li class="mb-2"><a href="/products/#corners" class="text-decoration-none text-white-50 hover-text-white transition-all">ركنات</a></li>
                        <li class="mb-2"><a href="/products/#dining" class="text-decoration-none text-white-50 hover-text-white transition-all">غرف سفرة</a></li>
                        <li class="mb-2"><a href="/products/#kitchens" class="text-decoration-none text-white-50 hover-text-white transition-all">مطابخ</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3 text-warning">تواصل معنا</h5>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-phone text-warning"></i> <span dir="ltr">{{ settings.contact.phone }}</span></li>
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-envelope text-warning"></i> {{ settings.contact.email }}</li>
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-map-marker-alt text-warning"></i> مدينة نصر، القاهرة</li>
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-map-marker-alt text-warning"></i> 6 أكتوبر، الجيزة</li>
                        <li class="mb-3 d-flex gap-2 align-items-center"><i class="fas fa-clock text-warning"></i> السبت - الخميس: 10 ص - 10 م</li>
                    </ul>
                </div>
            </div>
            
            <hr class="border-secondary my-4">
            
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-end mb-3 mb-md-0">
                    <p class="mb-0 text-white-50 small">&copy; {{ settings.footer.copyright }}</p>
                </div>
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0 text-white-50 small">{{ settings.footer.credits }}</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="/script.js"></script>

